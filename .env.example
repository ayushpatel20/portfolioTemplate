# ============================================================
#  Uifolio Portfolio — Environment Variables
#  Copy this file to .env for local development
#  Set these as Environment Variables in Vercel Dashboard
# ============================================================

# Server
PORT=3000
NODE_ENV=production

# Admin Login Credentials
# Used as fallback when database is unavailable (Vercel deployment)
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin123

# JWT Secret — generate a strong random string for production!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret-key

# Database (optional — for persisting contact messages and user management)
# Local development: uses SQLite automatically (prisma/dev.db)
# Production (Vercel): set this to a PostgreSQL connection string
#   e.g. from Neon (free): https://neon.tech
#   e.g. from Supabase (free): https://supabase.com
#   e.g. from Railway (free): https://railway.app
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
