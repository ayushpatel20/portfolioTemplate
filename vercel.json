{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["data/**", "components/**"]
      }
    },
    { "src": "*.html",        "use": "@vercel/static" },
    { "src": "assets/**",     "use": "@vercel/static" },
    { "src": "images/**",     "use": "@vercel/static" },
    { "src": "data/**",       "use": "@vercel/static" },
    { "src": "components/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)",        "dest": "/server.js"  },
    { "src": "/admin/dashboard", "dest": "/admin.html" },
    { "src": "/admin$",          "dest": "/admin.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",            "dest": "/index.html" }
  ]
}
