{
  "functions": {
    "api/index.js": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/admin/dashboard", "destination": "/admin.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/((?!api|admin|assets|images|data|components).*)*", "destination": "/index.html" }
  ]
}
