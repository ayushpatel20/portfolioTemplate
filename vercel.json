{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/blog",
      "dest": "/blog.html"
    },
    {
      "src": "/blog-details",
      "dest": "/blog-details.html"
    },
    {
      "src": "/project-details",
      "dest": "/project-details.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
