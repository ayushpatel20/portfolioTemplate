{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["data/**", "components/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)",         "dest": "/server.js" },
    { "src": "/admin/dashboard",  "dest": "/admin.html" },
    { "src": "/admin$",           "dest": "/admin.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",             "dest": "/index.html" }
  ]
}
